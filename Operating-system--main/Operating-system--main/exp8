#include <stdio.h>

int main() {
    int n, m, i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    printf("Enter number of resources: ");
    scanf("%d", &m);

    int allocation[n][m], request[n][m], available[m];
    int finish[n];

    printf("\nEnter Allocation Matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            scanf("%d", &allocation[i][j]);
        }
    }

    printf("\nEnter Request Matrix:\n");
    for(i = 0; i < n; i++) {
        for(j = 0; j < m; j++) {
            scanf("%d", &request[i][j]);
        }
    }

    printf("\nEnter Available Resources:\n");
    for(i = 0; i < m; i++) {
        scanf("%d", &available[i]);
    }

    for(i = 0; i < n; i++)
        finish[i] = 0;

    int work[m];
    for(i = 0; i < m; i++)
        work[i] = available[i];

    int found, k;

    do {
        found = 0;

        for(i = 0; i < n; i++) {
            if(finish[i] == 0) {

                int flag = 0;
                for(j = 0; j < m; j++) {
                    if(request[i][j] > work[j]) {
                        flag = 1;
                        break;
                    }
                }

                if(flag == 0) {
                    for(k = 0; k < m; k++)
                        work[k] += allocation[i][k];

                    finish[i] = 1;
                    found = 1;
                }
            }
        }

    } while(found);

    int deadlock = 0;

    for(i = 0; i < n; i++) {
        if(finish[i] == 0) {
            printf("Process P%d is in Deadlock\n", i);
            deadlock = 1;
        }
    }

    if(deadlock == 0)
        printf("No Deadlock Detected\n");

    return 0;
}
